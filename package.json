{
  "name": "god-kit",
  "version": "0.5.0",
  "description": "God Kit — design tokens and Vue 3 primitives for God Plan apps",
  "license": "MIT",
  "author": "God Plan Team",
  "private": false,
  "repository": {
    "type": "git",
    "url": "https://github.com/god-plans/god-kit.git"
  },
  "homepage": "https://god-plans.github.io/god-kit/",
  "bugs": {
    "url": "https://github.com/god-plans/god-kit/issues"
  },
  "funding": {
    "type": "github",
    "url": "https://github.com/sponsors/god-plans"
  },
  "keywords": [
    "vue",
    "vue3",
    "nuxt",
    "nuxt4",
    "admin-dashboard",
    "ui-kit",
    "component-library",
    "design-system",
    "design-tokens",
    "typescript"
  ],
  "engines": {
    "node": ">=20",
    "npm": ">=10"
  },
  "type": "module",
  "sideEffects": [
    "**/*.css"
  ],
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "exports": {
    ".": {
      "types": "./dist/vue.d.ts",
      "import": "./dist/vue.js"
    },
    "./vue": {
      "types": "./dist/vue.d.ts",
      "import": "./dist/vue.js"
    },
    "./vue/form": {
      "types": "./dist/vue-form.d.ts",
      "import": "./dist/vue-form.js"
    },
    "./vue/layout": {
      "types": "./dist/vue-layout.d.ts",
      "import": "./dist/vue-layout.js"
    },
    "./vue/navigation": {
      "types": "./dist/vue-navigation.d.ts",
      "import": "./dist/vue-navigation.js"
    },
    "./vue/config": {
      "types": "./dist/vue-config.d.ts",
      "import": "./dist/vue-config.js"
    },
    "./tokens.css": "./dist/tokens.css",
    "./vue.css": "./dist/assets/style.css",
    "./bridge/vuetify.css": "./dist/bridge/vuetify-bridge.css"
  },
  "scripts": {
    "build": "vite build && node scripts/postbuild-copy.mjs",
    "release:check": "npm run build && npm run test && npm publish --dry-run",
    "playground": "vite --config playground/vite.config.ts",
    "playground:build": "vite build --config playground/vite.config.ts",
    "docs:dev": "vitepress dev docs",
    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs",
    "test": "vitest run",
    "test:watch": "vitest",
    "new-component": "node scripts/new-component.mjs"
  },
  "peerDependencies": {
    "vue": "^3.5.0"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^5.2.1",
    "@vue/test-utils": "^2.4.6",
    "axe-core": "^4.11.1",
    "jsdom": "^25.0.1",
    "typescript": "^5.7.2",
    "vite": "^5.4.11",
    "vite-plugin-dts": "^4.4.0",
    "vitepress": "^1.6.3",
    "vitest": "^2.1.8",
    "vue": "^3.5.13",
    "vue-tsc": "^2.1.10"
  }
}
